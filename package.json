{
  "name": "nodoff",
  "description": "Sleep timer that pauses audio/video after a configurable timeout",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:preview": "vite --config vite.preview.config.ts",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "fmt": "prettier --write .",
    "lint": "eslint .",
    "type-check": "vue-tsc --noEmit",
    "generate-icons": "bun run scripts/generate-icons.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@wxt-dev/module-vue": "^1.0.3",
    "vue": "^3.5.30",
    "wxt": "^0.20.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vue-tsc": "^3.2.6"
  }
}
